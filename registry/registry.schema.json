{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SPUX Registry",
  "description": "Maps friendly aliases to script paths within the SPUX repo.",
  "type": "object",
  "required": ["version", "official"],
  "properties": {
    "version": { "type": "string" },
    "updated": { "type": "string", "format": "date" },
    "official":  { "$ref": "#/definitions/aliasMap" },
    "community": { "$ref": "#/definitions/aliasMap" }
  },
  "definitions": {
    "aliasMap": {
      "type": "object",
      "patternProperties": {
        "^[a-z0-9][a-z0-9-]*$": { "$ref": "#/definitions/entry" }
      },
      "additionalProperties": false
    },
    "entry": {
      "type": "object",
      "required": ["path", "title", "description", "platform"],
      "properties": {
        "path":        { "type": "string" },
        "title":       { "type": "string" },
        "description": { "type": "string" },
        "platform":    { "type": "array", "items": { "enum": ["macOS", "Linux", "Windows"] } },
        "verified":    { "type": "boolean", "default": false },
        "author":      { "type": "string" }
      }
    }
  }
}
